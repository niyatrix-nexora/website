# Django environment configuration template
DJANGO_SECRET_KEY=your-production-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,.vercel.app
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://*.vercel.app
SHEET_URL=https://script.google.com/macros/s/.../exec

# Vercel deployment:
# 1. Set all variables above in Vercel Dashboard → Project Settings → Environment Variables
# 2. IMPORTANT: Generate a new DJANGO_SECRET_KEY for production
# 3. Add your Vercel domain to DJANGO_ALLOWED_HOSTS
# 4. Add https://your-vercel-domain.vercel.app to DJANGO_CSRF_TRUSTED_ORIGINS

# Local LAN testing:
# 1. Set DJANGO_DEBUG=True in .env.
# 2. Run: python manage.py runserver 0.0.0.0:8000
# 3. Open: http://YOUR_COMPUTER_IP:8000/
# If DJANGO_ALLOWED_HOSTS is set locally, include YOUR_COMPUTER_IP in it.
